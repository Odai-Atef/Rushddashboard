# Rushd Platform - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files with real secrets to version control

# Application
VITE_APP_NAME=Rushd Platform
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="AI-driven platform for business decisions"

# API Configuration
VITE_API_BASE_URL=https://api.rushd-platform.com/v1
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3

# Feature Flags
VITE_ENABLE_AI_ANALYSIS=true
VITE_ENABLE_REAL_TIME_NOTIFICATIONS=false
VITE_ENABLE_DARK_MODE_BY_DEFAULT=true

# Authentication
VITE_AUTH_TOKEN_KEY=rushd_auth_token
VITE_REFRESH_TOKEN_KEY=rushd_refresh_token
VITE_TOKEN_EXPIRY_DAYS=7

# Analytics & Monitoring
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_TRACKING_ID=

# Development
VITE_DEV_MOCK_API=true
VITE_DEV_DELAY_MS=0
